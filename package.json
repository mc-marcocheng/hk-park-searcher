{
    "name": "park-searcher",
    "version": "1.0.0",
    "description": "Park Searcher",
    "scripts": {
        "start": "npm run build:data && echo \"Run a static server such as npx serve .\"",
        "build": "npm run validate:data && npm run build:data && node scripts/build-site.mjs",
        "build:data": "node scripts/build-parks.mjs",
        "validate:data": "node scripts/validate-parks.mjs",
        "migrate:data": "node scripts/migrate-parks.mjs",
        "lint": "eslint js/**/*.js scripts/**/*.mjs",
        "lint:fix": "eslint js/**/*.js scripts/**/*.mjs --fix",
        "format": "prettier --write \"**/*.{js,mjs,html,css,json}\"",
        "prepare": "husky",
        "images": "node scripts/optimize-images.mjs",
        "images:clean": "node scripts/optimize-images.mjs --clean"
    },
    "author": "McCheng",
    "license": "MIT",
    "devDependencies": {
        "eslint": "^10.2.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.1",
        "sharp": "^0.34.5"
    }
}
